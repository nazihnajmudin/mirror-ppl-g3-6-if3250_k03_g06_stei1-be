# ==============================================================
# Salin file ini menjadi .env dan isi nilainya sesuai kebutuhan
# JANGAN commit file .env
# ==============================================================

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Server
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# SSO ITB
SSO_BASE_URL=https://sso.itb.ac.id
SSO_CLIENT_ID=your_sso_client_id
SSO_CLIENT_SECRET=your_sso_client_secret
SSO_CALLBACK_URL=http://localhost:8000/api/auth/sso/callback

# File Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
MAX_FILE_SIZE_MB=10 

# Security
SESSION_SECRET=your_session_secret_key