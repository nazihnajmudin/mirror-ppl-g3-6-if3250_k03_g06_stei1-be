generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prodi {
  id            String             @id @default(uuid())
  fullname      String             @unique
  abbreviation  String?
  degree        String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  accreditation AccreditationInfo?
  documentLED   DocumentLED[]
  documentLKPS  DocumentLKPS[]
  assignments   ProdiAssignment[]
  users         User[]
}

model User {
  id          String            @id @default(uuid())
  email       String            @unique
  name        String
  password    String
  role        Role
  isActive    Boolean           @default(true)
  prodiId     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  documentLED DocumentLED[]
  assignments ProdiAssignment[]
  prodi       Prodi?            @relation(fields: [prodiId], references: [id])
}

model ProdiAssignment {
  id        String   @id @default(uuid())
  userId    String
  prodiId   String
  kriteria  String[] @default([])
  createdAt DateTime @default(now())
  prodi     Prodi    @relation(fields: [prodiId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, prodiId])
}

model AccreditationInfo {
  id             String    @id @default(uuid())
  prodiId        String    @unique
  grade          String?
  startDate      DateTime?
  endDate        DateTime?
  certificateUrl String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  prodi          Prodi     @relation(fields: [prodiId], references: [id])
}

model DocumentLKPS {
  id               String         @id @default(uuid())
  prodiId          String
  name             String?
  status           DocumentStatus @default(DRAFT)
  content          Json?
  filePath         String?
  originalFilename String?
  lockedAt         DateTime?
  lockedBy         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  periode          String?
  prodi            Prodi          @relation(fields: [prodiId], references: [id])
}

model DocumentLED {
  id           String         @id @default(uuid())
  prodiId      String
  name         String?
  status       DocumentStatus @default(DRAFT)
  content      String?
  lockedAt     DateTime?
  lockedBy     String?
  ukuran       Int?
  periode      String
  versi        Int
  pengunggahId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  pengunggah   User           @relation(fields: [pengunggahId], references: [id])
  prodi        Prodi          @relation(fields: [prodiId], references: [id])

  @@unique([prodiId, periode, versi])
}

model LEDForm {
  id          String          @id @default(uuid())
  prodiId     String
  template    String
  category    Category   
  periode     String     
  content     Json?         
  status      DocumentStatus   @default(DRAFT)
  CreatedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  editor      User?            @relation(fields: [lastSavedBy], references: [id])
  prodi       Prodi            @relation(fields: [prodiId], references: [id])

  @@unique([prodiId, periode, category])
}

enum Role {
  SUPER_ADMIN
  PIMPINAN
  KAPRODI
  TIM_PRODI
}

enum DocumentStatus {
  DRAFT
  FINAL
}

enum Category {
  INFOKOM
  LAM_TEKNIK
}