generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prodi {
  id            String             @id @default(uuid())
  fullname      String             @unique
  abbreviation  String?
  degree        String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  accreditation AccreditationInfo?
  documentLED   DocumentLED[]
  documentLKPS  DocumentLKPS[]
  assignments   ProdiAssignment[]
  users         User[]
  dokumenEviden DokumenEviden[]
  ledForms      LedForm[]
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  name          String
  password      String
  role          Role
  isActive      Boolean            @default(true)
  prodiId       String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  documentLED   DocumentLED[]
  assignments   ProdiAssignment[]
  templates     DocumentTemplate[]
  dokumenEviden DokumenEviden[]
  ledForms      LedForm[]
  prodi         Prodi?             @relation(fields: [prodiId], references: [id])
}

model ProdiAssignment {
  id        String   @id @default(uuid())
  userId    String
  prodiId   String
  kriteria  String[] @default([])
  createdAt DateTime @default(now())
  prodi     Prodi    @relation(fields: [prodiId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, prodiId])
}

model AccreditationInfo {
  id                      String    @id @default(uuid())
  prodiId                 String    @unique
  grade                   String?
  startDate               DateTime?
  endDate                 DateTime?
  certificateUrl          String?
  certificateOriginalName String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  prodi                   Prodi     @relation(fields: [prodiId], references: [id])
}

model DocumentLKPS {
  id               String         @id @default(uuid())
  prodiId          String
  name             String?
  status           DocumentStatus @default(DRAFT)
  content          Json?
  filePath         String?
  originalFilename String?
  lockedAt         DateTime?
  lockedBy         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  periode          String?
  versi            Int            @default(1)
  
  prodi            Prodi          @relation(fields: [prodiId], references: [id])
  criterias        LKPSCriteria[]

  @@unique([prodiId, periode, versi])
}

model LKPSCriteria {
  id              String          @id @default(uuid())
  documentId      String    
  document        DocumentLKPS    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  criteriaCode    String        
  criteriaName    String        
  subCriteriaCode String?
  subCriteriaName String?       
  sheets          LKPSSheetData[]
  isCompleted     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([documentId, criteriaCode, subCriteriaCode])
}

model LKPSSheetData {
  id              String        @id @default(uuid())
  criteriaId      String        
  criteria        LKPSCriteria  @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  sheetName       String        
  sheetTitle      String?
  data            Json          
  isCompleted     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([criteriaId, sheetName])
}

model DocumentLED {
  id           String         @id @default(uuid())
  prodiId      String
  name         String?
  status       DocumentStatus @default(DRAFT)
  content      String?
  lockedAt     DateTime?
  lockedBy     String?
  ukuran       Int?
  periode      String
  versi        Int
  pengunggahId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  pengunggah   User           @relation(fields: [pengunggahId], references: [id])
  prodi        Prodi          @relation(fields: [prodiId], references: [id])

  @@unique([prodiId, periode, versi])
}

model LedForm {
  id          String         @id @default(uuid())
  prodiId     String
  template    Template
  periode     String
  versi       Int            @default(1)
  status      DocumentStatus @default(DRAFT)
  content     Json
  lockedAt    DateTime?
  lockedBy    String?
  createdById String
  createdAt   DateTime       @default(now())
  
  prodi       Prodi    @relation(fields: [prodiId], references: [id])
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@unique([prodiId, periode, template, versi])
}

model DocumentTemplate {
  id           String       @id @default(uuid())
  name         String       
  type         TemplateType 
  category     LamCategory  
  content      String       
  uploadedById String
  uploader     User         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([type, category]) 
}

model DokumenEviden {
  id          String         @id @default(uuid())
  prodiId     String
  judul       String
  deskripsi   String?        @db.Text
  indikator   String[]       @default([]) 
  periode     String?
  status      DocumentStatus @default(DRAFT)
  lockedAt    DateTime?
  lockedBy    String?
  
  uploaderId  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  prodi       Prodi        @relation(fields: [prodiId], references: [id])
  uploader    User         @relation(fields: [uploaderId], references: [id])
  files       EvidenFile[]
}

model EvidenFile {
  id               String         @id @default(uuid())
  evidenId         String
  originalFilename String
  savedFilename    String         
  mimeType         String         
  size             Int            
  createdAt        DateTime       @default(now())
  eviden           DokumenEviden  @relation(fields: [evidenId], references: [id], onDelete: Cascade)
}

enum Template {
  INFOKOM
  LAM_TEKNIK
}

enum Role {
  SUPER_ADMIN
  PIMPINAN
  KAPRODI
  TIM_PRODI
}

enum DocumentStatus {
  DRAFT
  FINAL
}

enum LamCategory {
  INFOKOM
  TEKNIK
}

enum TemplateType {
  LKPS
  LED
}