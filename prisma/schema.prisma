generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prodi {
  id                    String                   @id @default(uuid())
  fullname              String                   @unique
  abbreviation          String?
  degree                String?
  category              String                   @default("TEKNIK")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  accreditation         AccreditationInfo?
  documentLED           DocumentLED[]
  documentLKPS          DocumentLKPS[]
  assignments           ProdiAssignment[]
  users                 User[]
  dokumenEviden         DokumenEviden[]
  ledForms              LedForm[]
  dataInstitusi         DataInstitusi[]
  notifications         Notification[]
  simulation            AccreditationSimulation?
  monitoringEvaluations MonitoringEvaluation[]
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  name                  String
  password              String
  role                  Role
  isActive              Boolean                @default(true)
  prodiId               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  documentLED           DocumentLED[]
  assignments           ProdiAssignment[]
  templates             DocumentTemplate[]
  dokumenEviden         DokumenEviden[]
  ledForms              LedForm[]
  prodi                 Prodi?                 @relation(fields: [prodiId], references: [id])
  dataInstitusi         DataInstitusi[]
  monitoringEvaluations MonitoringEvaluation[]
}

model ProdiAssignment {
  id        String   @id @default(uuid())
  userId    String
  prodiId   String
  kriteria  String[] @default([])
  createdAt DateTime @default(now())
  prodi     Prodi    @relation(fields: [prodiId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, prodiId])
}

model AccreditationInfo {
  id                      String    @id @default(uuid())
  prodiId                 String    @unique
  grade                   String?
  startDate               DateTime?
  endDate                 DateTime?
  certificateUrl          String?
  certificateOriginalName String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  prodi                   Prodi     @relation(fields: [prodiId], references: [id])
}

model DocumentLKPS {
  id               String         @id @default(uuid())
  prodiId          String
  name             String?
  status           DocumentStatus @default(DRAFT)
  content          Json?
  filePath         String?
  originalFilename String?
  lockedAt         DateTime?
  lockedBy         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  periode          String?
  versi            Int            @default(1)

  prodi                 Prodi                  @relation(fields: [prodiId], references: [id])
  criterias             LKPSCriteria[]
  monitoringEvaluations MonitoringEvaluation[]

  @@unique([prodiId, periode, versi])
}

model AccreditationSimulation {
  id                String   @id @default(uuid())
  prodiId           String   @unique
  indicators        Json
  quantitativeScore Float    @default(0)
  qualitativeScore  Float    @default(0)
  totalScore        Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  prodi Prodi @relation(fields: [prodiId], references: [id], onDelete: Cascade)
}

model LKPSCriteria {
  id String @id @default(uuid())

  // Relation to parent document
  documentId String
  document   DocumentLKPS @relation(fields: [documentId], references: [id], onDelete: Cascade)

  criteriaCode String // "1", "2", "3", "4", "5", "6", "7"
  criteriaName String // "Visi Misi Tujuan", "Tata Pamong", dst

  subCriteriaCode String? // "2a", "2b", "3a", "3b", dst
  subCriteriaName String? //  "Kerjasama Pendidikan", "Penelitian", dst

  // Relation to sheets
  sheets LKPSSheetData[]

  // Tracking
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([documentId, criteriaCode, subCriteriaCode])
}

model LKPSSheetData {
  id String @id @default(uuid())

  // Relation to parent criteria
  criteriaId String
  criteria   LKPSCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)

  // Sheet identification
  sheetName  String // "1", "2a1", "2a2", "3a1", "3a2", "3b", dst
  sheetTitle String? // "Visi Misi", "Kurikulum RPS", dst (optional descriptive)

  data Json // Ini biar fleksible karena tiap sheet columnnya beda-beda

  // Tracking
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([criteriaId, sheetName])
}

model DocumentLED {
  id                    String                 @id @default(uuid())
  prodiId               String
  name                  String?
  status                DocumentStatus         @default(DRAFT)
  content               String?
  lockedAt              DateTime?
  lockedBy              String?
  ukuran                Int?
  periode               String
  versi                 Int
  pengunggahId          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  pengunggah            User                   @relation(fields: [pengunggahId], references: [id])
  prodi                 Prodi                  @relation(fields: [prodiId], references: [id])
  monitoringEvaluations MonitoringEvaluation[]

  @@unique([prodiId, periode, versi])
}

model LedForm {
  id          String         @id @default(uuid())
  prodiId     String
  template    Template
  periode     String
  versi       Int            @default(1)
  status      DocumentStatus @default(DRAFT)
  content     Json
  lockedAt    DateTime?
  lockedBy    String?
  createdById String
  createdAt   DateTime       @default(now())

  prodi     Prodi @relation(fields: [prodiId], references: [id])
  createdBy User  @relation(fields: [createdById], references: [id])

  @@unique([prodiId, periode, template, versi])
}

model DocumentTemplate {
  id       String       @id @default(uuid())
  name     String // Contoh: "Template LKPS LAM Teknik 2026"
  type     TemplateType // LKPS atau LED
  category LamCategory // INFOKOM atau TEKNIK
  content  String // Path file fisik dari Storage Provider

  uploadedById String
  uploader     User   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, category])
}

model DokumenEviden {
  id        String         @id @default(uuid())
  prodiId   String
  judul     String
  deskripsi String?        @db.Text
  indikator String[]       @default([])
  periode   String?
  status    DocumentStatus @default(DRAFT)
  lockedAt  DateTime?
  lockedBy  String?

  uploaderId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prodi                 Prodi                  @relation(fields: [prodiId], references: [id])
  uploader              User                   @relation(fields: [uploaderId], references: [id])
  files                 EvidenFile[]
  monitoringEvaluations MonitoringEvaluation[]
}

model EvidenFile {
  id               String @id @default(uuid())
  evidenId         String
  originalFilename String
  savedFilename    String // Nama file fisik di storage
  mimeType         String // Untuk icon di frontend (misal: application/pdf)
  size             Int // Dalam bytes

  createdAt DateTime @default(now())

  // Relasi
  eviden DokumenEviden @relation(fields: [evidenId], references: [id], onDelete: Cascade) // Jika Eviden dihapus, file juga terhapus
}

model DataInstitusi {
  id        String  @id @default(uuid())
  periode   String // Contoh: "2025/2026"
  sheetName String // Kode sheet LKPS, contoh: "2b"
  prodiId   String?
  data      Json // Menyimpan array of objects data UPPS

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
  prodi       Prodi? @relation(fields: [prodiId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Mencegah duplikasi data untuk sheet dan periode yang sama
  @@unique([periode, sheetName])
}

model Notification {
  id        String           @id @default(uuid())
  prodiId   String?
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  targetUrl String?
  createdAt DateTime         @default(now())
  prodi     Prodi?           @relation(fields: [prodiId], references: [id])
}

model ThresholdConfig {
  id        String   @id @default(uuid())
  name      String   @unique
  value     Int
  updatedAt DateTime @updatedAt
}

model MonitoringEvaluation {
  id             String                 @id @default(uuid())
  documentType   MonitoringDocumentType
  documentRefId  String
  documentLabel  String
  prodiId        String
  indicatorCode  String?
  indicatorName  String
  note           String                 @db.Text
  evaluation     String?                @db.Text
  recommendation String?                @db.Text
  status         MonitoringStatus       @default(OPEN)
  reviewedAt     DateTime?
  createdById    String
  lkpsId         String?
  ledId          String?
  evidenId       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  createdBy User           @relation(fields: [createdById], references: [id])
  prodi     Prodi          @relation(fields: [prodiId], references: [id], onDelete: Cascade)
  lkps      DocumentLKPS?  @relation(fields: [lkpsId], references: [id], onDelete: Cascade)
  led       DocumentLED?   @relation(fields: [ledId], references: [id], onDelete: Cascade)
  eviden    DokumenEviden? @relation(fields: [evidenId], references: [id], onDelete: Cascade)

  @@index([documentType, documentRefId])
  @@index([createdById])
  @@index([prodiId])
}

enum Template {
  INFOKOM
  LAM_TEKNIK
}

enum Role {
  SUPER_ADMIN
  PIMPINAN
  KAPRODI
  TIM_PRODI
}

enum DocumentStatus {
  DRAFT
  FINAL
}

enum LamCategory {
  INFOKOM
  TEKNIK
}

enum TemplateType {
  LKPS
  LED
}

enum NotificationType {
  INFO
  WARNING
  DANGER
}

enum MonitoringDocumentType {
  LKPS
  LED
  EVIDEN
}

enum MonitoringStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}
