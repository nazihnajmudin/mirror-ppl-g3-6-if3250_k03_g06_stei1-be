generator client {
  provider = "prisma-client-js"
  //  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prodi {
  id          Int           @id @default(autoincrement())
  nama        String        @unique
  akreditasi  String?
  
  users       User[]
  dokumenLED  DokumenLED[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum Role {
  ADMIN_INSTITUSI
  PIMPINAN
  KAPRODI
  ADMIN_PRODI
  DOSEN
}

model User {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  name        String
  password    String?
  role        Role
  isActive    Boolean       @default(true)

  prodiId     Int?
  prodi       Prodi?        @relation(fields: [prodiId], references: [id])
  
  dokumenLED  DokumenLED[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model DokumenLED {
  id           Int      @id @default(autoincrement())
  namaFile     String 
  pathFile     String
  ukuran       Int
  
  periode      String
  versi        Int
  
  prodiId      Int
  prodi        Prodi    @relation(fields: [prodiId], references: [id])
  
  pengunggahId Int
  pengunggah   User     @relation(fields: [pengunggahId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Constraint: Tidak boleh ada 2 dokumen dengan versi yang sama di prodi dan periode yang sama
  @@unique([prodiId, periode, versi]) 
}