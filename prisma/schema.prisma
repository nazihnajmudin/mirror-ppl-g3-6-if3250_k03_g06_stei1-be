generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prodi {
  id            String             @id @default(uuid())
  fullname      String             @unique
  abbreviation  String?
  degree        String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  accreditation AccreditationInfo?
  documentLED   DocumentLED[]
  documentLKPS  DocumentLKPS[]
  assignments   ProdiAssignment[]
  users         User[]
  dokumenEviden DokumenEviden[]
  ledForms      LedForm[]
}

model User {
  id          String            @id @default(uuid())
  email       String            @unique
  name        String
  password    String
  role        Role
  isActive    Boolean           @default(true)
  prodiId     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  documentLED DocumentLED[]
  assignments ProdiAssignment[]
  templates   DocumentTemplate[]
  dokumenEviden DokumenEviden[]
  ledForms    LedForm[]
  prodi       Prodi?            @relation(fields: [prodiId], references: [id])
}

model ProdiAssignment {
  id        String   @id @default(uuid())
  userId    String
  prodiId   String
  createdAt DateTime @default(now())
  kriteria  String[] @default([])
  prodi     Prodi    @relation(fields: [prodiId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, prodiId])
}

model AccreditationInfo {
  id             String    @id @default(uuid())
  prodiId        String    @unique
  grade          String?
  startDate      DateTime?
  endDate        DateTime?
  certificateUrl String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  prodi          Prodi     @relation(fields: [prodiId], references: [id])
}

model DocumentLKPS {
  id               String         @id @default(uuid())
  prodiId          String
  name             String?
  status           DocumentStatus @default(DRAFT)
  content          Json?
  filePath         String?
  originalFilename String?
  lockedAt         DateTime?
  lockedBy         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  periode          String?
  prodi            Prodi          @relation(fields: [prodiId], references: [id])
}

model DocumentLED {
  id           String         @id @default(uuid())
  prodiId      String
  name         String?
  status       DocumentStatus @default(DRAFT)
  content      String?
  lockedAt     DateTime?
  lockedBy     String?
  ukuran       Int?
  periode      String
  versi        Int
  pengunggahId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  pengunggah   User           @relation(fields: [pengunggahId], references: [id])
  prodi        Prodi          @relation(fields: [prodiId], references: [id])

  @@unique([prodiId, periode, versi])
}

model DocumentTemplate {
  id          String       @id @default(uuid())
  name        String       // Contoh: "Template LKPS LAM Teknik 2026"
  type        TemplateType // LKPS atau LED
  category    LamCategory  // INFOKOM atau TEKNIK
  content     String       // Path file fisik dari Storage Provider
  
  uploadedById String
  uploader     User        @relation(fields: [uploadedById], references: [id])
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([type, category]) 
}

model DokumenEviden {
  id          String   @id @default(uuid())
  prodiId     String
  judul       String
  deskripsi   String?  @db.Text
  indikator   String[] @default([]) 
  periode     String?
  
  uploaderId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prodi       Prodi    @relation(fields: [prodiId], references: [id])
  uploader    User     @relation(fields: [uploaderId], references: [id])
  files       EvidenFile[]
}

model EvidenFile {
  id               String         @id @default(uuid())
  evidenId         String
  originalFilename String
  savedFilename    String         // Nama file fisik di storage
  mimeType         String         // Untuk icon di frontend (misal: application/pdf)
  size             Int            // Dalam bytes
  
  createdAt        DateTime       @default(now())

  // Relasi
  eviden           DokumenEviden  @relation(fields: [evidenId], references: [id], onDelete: Cascade) // Jika Eviden dihapus, file juga terhapus
}

model LedForm {
  id          String   @id @default(uuid())
  prodiId     String
  template    Template
  periode     String
  content     Json
  createdById String
  createdAt   DateTime @default(now())
  prodi       Prodi    @relation(fields: [prodiId], references: [id])
  createdBy   User     @relation(fields: [createdById], references: [id])
}

enum Template {
  INFOKOM
  LAM_TEKNIK
}

enum Role {
  SUPER_ADMIN
  PIMPINAN
  KAPRODI
  TIM_PRODI
}

enum DocumentStatus {
  DRAFT
  FINAL
}

enum LamCategory {
  INFOKOM
  TEKNIK
}

enum TemplateType {
  LKPS
  LED
}