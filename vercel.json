{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/.prisma/client/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ],
  "functions": {
    "src/server.ts": {
      "runtime": "@vercel/node@canary"
    }
  },
  "installCommand": "npm install && npx prisma generate",
  "buildCommand": "tsc --noImplicitAny false --skipLibCheck true && tsc-alias -p tsconfig.json"
}