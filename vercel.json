{
  "version": 2,
  "installCommand": "npm install && npx prisma generate",
  "buildCommand": "npm run build",
  "functions": {
    "src/server.ts": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ]
}